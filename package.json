{
  "name": "lcdos-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down -v",
    "db:setup": "python scripts/replication/setup-replication.py",
    "db:verify": "python scripts/replication/verify-replication.py",
    "dev:api-pusat": "tsx apps/api-pusat/src/main.ts",
    "dev:api-tasikmalaya": "tsx apps/api-tasikmalaya/src/main.ts",
    "dev:api-surabaya": "tsx apps/api-surabaya/src/main.ts",
    "dev:api-malang": "tsx apps/api-malang/src/main.ts",
    "prisma:generate": "prisma generate --schema packages/shared/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema packages/shared/prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "devDependencies": {
    "@prisma/client": "^6.12.0",
    "@types/node": "^22.16.5",
    "prisma": "^6.12.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
